# AI Wrapper - Environment Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_wrapper
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ai_wrapper

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Auth
SECRET_KEY=change-me-to-a-random-secret-in-production

# Docker Sandbox
SANDBOX_IMAGE=node:20-slim
SANDBOX_TIMEOUT=300
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0

# Deployment (optional)
VERCEL_TOKEN=
CLOUDFLARE_TOKEN=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App
DEBUG=true
